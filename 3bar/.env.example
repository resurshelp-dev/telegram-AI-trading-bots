# BingX credentials
BINGX_API_KEY=
BINGX_SECRET_KEY=

# Safety: keep paper mode enabled until you explicitly switch to live
PAPER=true

# Instrument
SYMBOL=ETH-USDT

# Strategy / risk
INITIAL_CAPITAL=100
RISK_PERCENT=10
LIVE_DAYS=180
LOOKBACK_BARS=6
MAX_SIGNAL_AGE_MINUTES=180
POLL_SECONDS=60
HEARTBEAT_MINUTES=60

# 3bar system defaults
LEVEL_MODE=rolling_window
LEVEL_LOOKBACK_BARS=6
LEVEL_TOLERANCE_ATR=0.8
LONG_TREND_FILTER=ema
SHORT_TREND_FILTER=none
MIN_PIN_WICK_BODY_RATIO=0.35
MIN_PIN_RANGE_ATR=0.60
TRAIL_ACTIVATION_R=1.4
TRAIL_LOOKBACK_BARS=4
MAX_HOLD_BARS=48

# Optional exchange formatting
QTY_PRECISION=6
PRICE_PRECISION=2
RECV_WINDOW=5000

# Optional telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BOT_TAG=3bar-live
