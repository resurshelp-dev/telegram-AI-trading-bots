# BingX credentials
BINGX_API_KEY=
BINGX_SECRET_KEY=

# Safety: keep paper mode enabled until you explicitly switch to live
PAPER=true

# Default instrument
SYMBOL=ETH-USDT

# Unified live system settings
INITIAL_CAPITAL=10000
RISK_PERCENT=1
TREND_PROFILE=profit_max_locked
SWEEP_PROFILE=off
DATA_MODE=live
LIVE_DAYS=30
LOOKBACK_BARS=6
ENTRY_TOLERANCE_R=0.25
MAX_SIGNAL_AGE_MINUTES=180
POLL_SECONDS=60
HEARTBEAT_MINUTES=30
PAPER_MAX_HOLD_MINUTES=480
PAPER_FEE_PER_SIDE=0.0005

# Optional exchange formatting
QTY_PRECISION=6
PRICE_PRECISION=2
RECV_WINDOW=5000
